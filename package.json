{
  "name": "open-with-default-app",
  "publisher": "local-dev",
  "displayName": "Open with Default App",
  "repository": {
    "type": "git",
    "url": "https://github.com/local/open-with-default-app"
  },
  "license": "MIT",
  "description": "Opens files with the OS default application via explorer.exe (Windows only)",
  "version": "0.1.11",
  "os": [
    "win32"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "openWithDefaultApp.editor",
        "displayName": "Open with Default App",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Open with Default App",
      "properties": {
        "openWithDefaultApp.extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".xlsx",
            ".xls",
            ".xlsm",
            ".docx",
            ".doc",
            ".pptx",
            ".ppt",
            ".pdf",
            ".zip",
            ".tar",
            ".gz",
            ".7z",
            ".rar",
            ".exe",
            ".msi",
            ".mp3",
            ".mp4",
            ".avi",
            ".mov",
            ".mkv",
            ".wav",
            ".flac",
            ".psd",
            ".ai",
            ".sketch"
          ],
          "description": "List of file extensions to open with the OS default application. You can add any extension."
        },
        "openWithDefaultApp.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a file is opened with the default application."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-rewrite-relative-links"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
